# =============================================
# FormaPro MVP — Variables d'environnement
# =============================================
# Copiez ce fichier en .env et remplissez les valeurs

# ===== APP =====
NODE_ENV=production
PORT=3000
BASE_URL=https://formapro.up.railway.app

# ===== SECURITY (OBLIGATOIRE — générez avec: openssl rand -base64 64) =====
JWT_SECRET=CHANGEZ_MOI_openssl_rand_base64_64
JWT_REFRESH_SECRET=CHANGEZ_MOI_openssl_rand_base64_64_different

# ===== BASE DE DONNÉES =====
DB_PATH=./data/formapro.json

# ===== EMAIL (optionnel en beta — désactivé = logs console) =====
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=SG.votre_cle_sendgrid
# EMAIL_FROM=noreply@formapro.fr
# EMAIL_FROM_NAME=FormaPro

# ===== UPLOADS =====
UPLOADS_DIR=./uploads
MAX_FILE_SIZE_MB=10

# ===== STRIPE (phase 2 — laisser vide pour beta) =====
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
